{
  // 外銷實驗室 — 國際站 AI 團隊｜店長 工具註冊配置
  //
  // 此文件聲明 Agent 可使用哪些工具（註冊層），與權限層 (policy.jsonl) 正交。
  // 註冊 ≠ 無條件可調用：運行時校驗鏈為 註冊 → 能力層 → 權限層 → 執行。
  //
  // ⚠️ 維護提醒：profile.jsonc 的 toolInclude 與本文件的 builtin.include 需保持一致。
  //    若兩邊不同步，以 profile.jsonc 為 Accio 運行時實際依據。
  "version": 1,

  // 店長是團隊指揮，採用 tl 類工具集：除標準工具外，額外具備調度與管理其他成員的能力。
  "preset": "none",

  "builtin": {
    "include": [
      "list", "read", "grep", "glob", "ripgrep", "write", "edit",
      "web_search", "web_fetch",
      "bash", "process", "cron",
      "see_image", "get_time", "get_location",
      "ask_user",
      "memory_search", "memory_get",
      "task_create", "task_get", "task_update", "task_list",
      "sessions_spawn", "sessions_list", "sessions_history", "sessions_send",
      "create_agent", "list_agent", "delete_agent", "invite_agent", "remove_agent"
    ],
    "exclude": []
  },

  "mcp": [],
  "conditional": [],
  "notes": "店長是老闆的單一窗口，負責拆解任務並透過 sessions 機制分派給流量官、軍師、業務官、履約官。"
}
